{
  "name": "nms-eoc-backend",
  "version": "1.0.0",
  "description": "NMS Emergency Operations Center — Core API Service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src/**/*.ts --ext ts --exec npx tsx src/server.ts",
    "build": "prisma generate && tsc && node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive:true})\"",
    "start": "node dist/server.js",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "nms",
    "eoc",
    "fastify",
    "typescript"
  ],
  "author": "NMS",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/redis": "^7.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
